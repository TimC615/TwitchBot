<Window x:Class="TwitchBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TwitchBot"
        mc:Ignorable="d"
        Title="Twitch Bot" Height="466" Width="560" Closing="MainWindow_Closing" ResizeMode="CanMinimize">
    <Grid x:Name="Twitch_Bot" Background="#FFE4D3BF" Margin="0,0,0,0">

        <StackPanel Orientation="Vertical">
            <!-- https://stackoverflow.com/questions/9936796/create-a-menu-bar-in-wpf -->
            <Menu VerticalAlignment="Top" Width="Auto" Height="20">
                <MenuItem Header="_File">
                    <MenuItem Name="Settings" Header="_Settings" HorizontalAlignment="Left" Click="SettingsButton_Click"/>
                    <MenuItem x:Name="AppExit" Header="Exit" HorizontalAlignment="Left" Click="CloseMenuItem_Click"/>
                </MenuItem>
                
                <MenuItem Header="_Launch">
                    <MenuItem Name="ConnectToTwitch" Header="_Start Bot" HorizontalAlignment="Left" Click="StartBotMenuItem_Click"/>
                    <MenuItem Name="StopBotMenuItem" Header="_Stop Bot" HorizontalAlignment="Left" IsEnabled="False" Click="StopBotMenuItem_Click"/>
                    <MenuItem Name="RestartBotMenuItem" Header="_Restart Bot" HorizontalAlignment="Left" IsEnabled="False" Click="RestartBotMenuItem_Click"/>
                    <Separator></Separator>
                    
                    <MenuItem Name="ConnectOnLaunchMenuItem" Header="_Start Bot on App Launch" HorizontalAlignment="Left" IsCheckable="True" Checked="ConnectBotOnLaunchMenuItem_Checked" Unchecked="ConnectBotOnLaunchMenuItem_Unchecked"/>
                    <Separator></Separator>
                    
                    <MenuItem Name="twitchPlaysButton" Header="_Start Twitch Plays" HorizontalAlignment="Left" IsEnabled="False" Click="TwitchPlaysButton_Click"/>
                </MenuItem>
                
                <MenuItem Header="_TTS">
                    <MenuItem Name="SpeechSynthPauseResume" Header="_Pause TTS" HorizontalAlignment="Left" IsEnabled="False" Click="PauseResumeTTSMenuItem_Click"/>
                    <Separator></Separator>
                    
                    <MenuItem Name="SpeechSynthClearAllPrompts" Header="_Clear TTS Queue" HorizontalAlignment="Left" IsEnabled="False" Click="ClearAllTTSPromptsMenuItem_Click"/>
                    <MenuItem Name="NinjaApiSilenceTTS" Header="_Silence Ninja API TTS" HorizontalAlignment="Left" IsEnabled="False" IsCheckable="True" Checked="SilenceNinjaApiTTSMenuItem_Checked" Unchecked="SilenceNinjaApiTTSMenuItem_Unchecked"/>
                </MenuItem>
                
                <MenuItem Header="_OBS">
                    <MenuItem Name="ConnectOBS" Header="_Connect OBS" HorizontalAlignment="Left" IsEnabled="False" Click="ConnectOBSMenuItem_Click"/>
                    <MenuItem Name="DisconnectOBS" Header="_Disconnect OBS" HorizontalAlignment="Left" IsEnabled="False" Click="DisconnectOBSMenuItem_Click"/>
                </MenuItem>

                <MenuItem Header="_Chat Commands">
                    <MenuItem Name="ShowRouletteSuccess" Header="_Display Roulette Success Message" HorizontalAlignment="Left" IsEnabled="False" IsCheckable="True" Checked="ShowRouletteSuccessMenuItem_Checked" Unchecked="ShowRouletteSuccessMenuItem_Unchecked"/>
                </MenuItem>

                <MenuItem Header="_Advanced">
                    <MenuItem Name="CheckCurrentAccessToken" Header="_Check Access Token" HorizontalAlignment="Left" IsEnabled="False" Click="CheckAccessTokenMenuItem_Click"/>
                    <Separator></Separator>
                    <MenuItem Name="RecreateTTSNormalRate" Header="_Recreate TTS (Normal Rate) Points Reward" HorizontalAlignment="Left" IsEnabled="False" Click="RecreateTTSNormalRateRewardMenuItem_Click"/>
                    <MenuItem Name="RecreateTTSRandomRate" Header="_Recreate TTS (Random Rate) Points Reward" HorizontalAlignment="Left" IsEnabled="False" Click="RecreateTTSRandomRateRewardMenuItem_Click"/>
                    <MenuItem Name="RecreateMovePNGMeReward" Header="_Recreate Move PNG-Me Points Reward" HorizontalAlignment="Left" IsEnabled="False" Click="RecreateMovePNGMeRewardMenuItem_Click"/>
                    <MenuItem Name="RecreateResetPNGMeReward" Header="_Recreate Reset PNG-Me Points Reward" HorizontalAlignment="Left" IsEnabled="False" Click="RecreateResetPNGMeRewardMenuItem_Click"/>
                    <MenuItem Name="RecreateToggleCakeFaceReward" Header="_Recreate Toggle Cake Face Points Reward" HorizontalAlignment="Left" IsEnabled="False" Click="RecreateToggleCakeFaceRewardMenuItem_Click"/>
                </MenuItem>
            </Menu>

            <TextBox x:Name="ConsoleLog" HorizontalAlignment="Left" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="540" Height="301" x:FieldModifier="public" Margin="10,20,10,0" Padding="0,0,5,0" IsReadOnly="True" VerticalScrollBarVisibility="Auto"/>

            <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                <!-- Button Name="twitchPlaysButtontest" Content="Start Twtich Plays" HorizontalAlignment="Left" Margin="30,0,0,0" VerticalAlignment="Center" Height="38" Width="144" IsEnabled="False" Click="TwitchPlaysButton_Click"/-->
                <Button x:Name="SkipCurrentTTSButton" Content="Skip Current TTS" Margin="15,0,0,0" VerticalAlignment="Center" Height="38" Width="115" Click="SkipCurrentTTS_Click" IsEnabled="false"/>
                <Button x:Name="CreateStreamMarkerButton" Margin="15,0,0,0" VerticalAlignment="Center" Height="38" Width="102" Click="CreateStreamMarker_Click" IsEnabled="false">
                    <TextBlock Text="Create Stream Marker" TextWrapping="Wrap" TextAlignment="Center"></TextBlock>
                </Button>
                <Button x:Name="TestButton" Margin="15,0,0,0" VerticalAlignment="Center" Height="38" Width="97" IsEnabled="True" Click="TestButton_Click">
                    <TextBlock Text="Test Button" TextWrapping="Wrap" TextAlignment="Center"></TextBlock>
                </Button>
                <Button x:Name="TestModButton" Content="Test Mod" Margin="15,0,0,0" VerticalAlignment="Center" Height="38" Width="66" IsEnabled="False" Click="TestModButton_Click"/>
                <Button x:Name="TestUnmodButton" Content="Test UnMod" Margin="15,0,0,0" VerticalAlignment="Center" Height="38" Width="77" IsEnabled="False" Click="TestUnmodButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
